# Public site URL (used for canonical, OG, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://hazlsolutions.com

# Sanity (get these from https://sanity.io/manage after creating a project)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Optional read token for previews/private datasets (not required for published content)
SANITY_API_READ_TOKEN=

# Shared secret for the /api/revalidate webhook
# Generate with: openssl rand -hex 32
SANITY_REVALIDATE_SECRET=
